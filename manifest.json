{
  "manifest_version": 3,
  "name": "Universal Task Timer",
  "version": "4.0",
  "description": "Professional Task Timer with Logs, Summary and Export",

  "permissions": [
    "storage",
    "downloads"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}